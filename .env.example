# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database (Phase 2+) ---
# Matches the docker-compose `db` service. Async driver for SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://ore:ore@db:5432/ore

# --- LLM providers (Phase 1+) ---
# Phase 1 uses Groq only (free). Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Added in Phase 7 (smart tier upgrade):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Observability (Phase 7, optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ore

# --- Frontend ---
# Base URL the browser uses to reach the backend.
VITE_API_URL=http://localhost:8000
